# Copy this file to .env and fill in your GNews API key.
# Get a free key at https://gnews.io
#
# For Vercel deployments: add this variable under
# Project → Settings → Environment Variables.
#
# Note: no VITE_ prefix — this key is read server-side by the /api/news
# serverless function and is never bundled into the client.

GNEWS_API_KEY=your_gnews_api_key_here
