# Copy this file to .env and fill in your API keys.
#
# For Vercel deployments: add these variables under
# Project → Settings → Environment Variables.
#
# Note: no VITE_ prefix — keys are read server-side by the /api/* serverless
# functions and are never bundled into the client.

# GNews API — get a free key at https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# The Guardian API — get a free key at https://open-platform.theguardian.com/access/
# Optional: if not set, The Guardian tab will show an error but other sources still load.
GUARDIAN_API_KEY=your_guardian_api_key_here
